{
  "name": "ikcp-family-office-mobile",
  "version": "1.0.0",
  "private": true,
  "description": "App mobile IKCP Family Office — wrap Capacitor de client.ikcp.eu pour iOS + Android",
  "scripts": {
    "sync": "cap sync",
    "ios": "cap open ios",
    "android": "cap open android",
    "build:ios": "cap sync ios && cap copy ios",
