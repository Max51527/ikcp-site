    "icons": "cordova-res ios --skip-config --copy && cordova-res android --skip-config --copy"
  },
  "dependencies": {
    "@capacitor/android": "^6.1.0",
    "@capacitor/biometric-auth": "^2.0.0",
    "@capacitor/core": "^6.1.0",
    "@capacitor/ios": "^6.1.0",
    "@capacitor/push-notifications": "^6.0.0",
    "@capacitor/splash-screen": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.1.0",
    "cordova-res": "^0.15.4",
    "typescript": "^5.4.0"
  }
}
