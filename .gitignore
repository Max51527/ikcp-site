# ═══════════════════════════════════════════════════════════
# IKCP — .gitignore
# Protège les secrets et fichiers locaux. Ne JAMAIS commiter ce qui suit.
# ═══════════════════════════════════════════════════════════

# Secrets — Cloudflare wrangler dev local
**/.dev.vars
**/.dev.vars.*
**/wrangler.toml.local
*.env
*.env.local
*.env.production
.env*

# Clés API — au cas où
**/api-keys*
**/secrets*
**/*.key
**/*.pem

# Wrangler — généré
**/.wrangler/
**/.mf/

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
package-lock.json
yarn.lock

# OS
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo
*~

# Logs
*.log
logs/

# Local data
*.db
*.sqlite
*.sqlite3
local/
data-local/

# Build artifacts
dist/
build/
.cache/
